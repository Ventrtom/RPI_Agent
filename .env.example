# Agent identity
AGENT_USER_NAME=Firstname Lastname

# ── POVINNÉ ────────────────────────────────────────────────────────────────────

# LLM
ANTHROPIC_API_KEY=your_key_here        # https://console.anthropic.com/
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=1024

# Telegram bot token — povinné pouze pro telegram mód
TELEGRAM_BOT_TOKEN=your_token_here     # BotFather na Telegramu: https://t.me/BotFather

# ── VOLITELNÉ ──────────────────────────────────────────────────────────────────

# Embeddings (Mem0) — výchozí model nevyžaduje API klíč
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Voice TTS — bez tohoto agentovy hlasové odpovědi nefungují
ELEVENLABS_API_KEY=your_key_here       # https://elevenlabs.io/
ELEVENLABS_VOICE_ID=your_voice_id_here # Najdeš v nastavení hlasu na ElevenLabs
ELEVENLABS_MODEL=eleven_multilingual_v2

# Voice STT — bez tohoto přepis hlasových zpráv nefunguje
GROQ_API_KEY=your_key_here             # https://console.groq.com/ (zdarma)
WHISPER_MODEL=whisper-large-v3-turbo
WHISPER_LANGUAGE=cs

# Web search — bez tohoto agent nemůže vyhledávat na internetu
TAVILY_API_KEY=your_tavily_api_key_here  # https://app.tavily.com/ (zdarma)

# Home Assistant — bez tohoto HA nástroje nejsou dostupné
HA_URL=http://homeassistant.local:8123   # Base URL of your HA instance
HA_TOKEN=your_long_lived_token_here      # Settings → Profile → Long-Lived Access Tokens
HA_TIMEOUT=10                            # HTTP timeout in seconds (default: 10)

# ── INTERNÍ KONFIGURACE ────────────────────────────────────────────────────────

# Session
SESSION_TIMEOUT_MINUTES=60
SESSION_CLEANUP_INTERVAL=300
SESSION_DB_PATH=./data/sessions.db

# Mem0 / ChromaDB
CHROMA_DB_PATH=./data/chroma
MEM0_USER_ID=user

# Scheduler
SCHEDULER_TIMEZONE=Europe/Prague
TASKS_DB_PATH=./data/tasks.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=agent.log
